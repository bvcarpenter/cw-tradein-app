{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cw-tradein-app",
  "compatibility_date": "2025-09-27",
  "observability": { "enabled": true },
  "assets": { "directory": "public" },
  "compatibility_flags": ["nodejs_compat"],
  "kv_namespaces": [
    {
      "binding": "SESSIONS_KV",
      "id": "REPLACE_WITH_YOUR_KV_NAMESPACE_ID"
    }
  ]
}